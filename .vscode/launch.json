{
  "version": "0.2.0",
  "configurations": [
    {
      "command": "./node_modules/.bin/astro dev",
      "name": "Server",
      "request": "launch",
      "type": "node-terminal"
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Client",
      "url": "http://localhost:4321",
      "webRoot": "${workspaceFolder}/src",
      "sourceMapPathOverrides": {
        "vite://src/*": "${webRoot}/*"
      },
      "skipFiles": ["**/node_modules/**"]
    }
  ],
  "compounds": [
    {
      "name": "Launch Dev Server and Chrome",
      "configurations": ["Server", "Client"],
      "stopAll": true
    }
  ]
}
