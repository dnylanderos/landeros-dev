---
import "@awesome.me/webawesome/dist/styles/webawesome.css"

import "../styles/global.css" // tailwind
import Base from "../layouts/Base.astro" // layout
import { getCollection } from "astro:content" // content collection

const allWorks = (await getCollection('works')).sort(
  (a, b) => b.data.date_end.valueOf() - a.data.date_end.valueOf(),
);
---

<!-- Web Awesome autoloader -->
<script
  type="module"
  src="https://ka-f.webawesome.com/webawesome@3.9.0/webawesome.loader.js"
></script>

<Base>
  <h1>Work</h1>
  {
    allWorks.map((work) => (
      <div class="job-card">
        <h2>{work.data.title}</h2>
      </div>
    ))
  }
</Base>
