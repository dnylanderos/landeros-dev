---
import "@awesome.me/webawesome/dist/styles/webawesome.css" // webawesome
import "../styles/global.css" // tailwind
import Base from "../layouts/Base.astro" // layout
import { getCollection } from "astro:content" // content collection

const allProjects = await getCollection("projects")
---

<!-- Web Awesome autoloader -->
<script
  type="module"
  src="https://ka-f.webawesome.com/webawesome@3.9.0/webawesome.loader.js"
></script>

<Base>
  <h1>Projects</h1>
  {
    allProjects.map((project) => (
      <div class="project-card">
        <h2>{project.data.title}</h2>
        <p>{project.data.description}</p>
      </div>
    ))
  }
</Base>
